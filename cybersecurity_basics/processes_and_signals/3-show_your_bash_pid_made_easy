#!/usr/bin/env bash
# This script shows PIDs and names of processes containing the word 'bash'
# shellcheck disable=SC2009
for pid in /proc/[0-9]*; do
    comm_file="$pid/comm"
    if [ -f "$comm_file" ]; then
        name=$(cat "$comm_file" 2>/dev/null)
        if echo "$name" | grep -q bash; then
            echo "$(basename "$pid") $name"
        fi
    fi
done
